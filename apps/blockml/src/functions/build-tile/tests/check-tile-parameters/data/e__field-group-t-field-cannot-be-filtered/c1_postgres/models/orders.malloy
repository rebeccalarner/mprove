##! experimental{sql_functions}

#(mprove) model
source: orders is c1_postgres.table('ecommerce.orders') extend {
  rename: _created_at_ts is created_at_ts
  
  #(mprove) build_metrics field_group="Created At"
  dimension:
    created_at_t is _created_at_ts
    created_at_ts is created_at_t

  measure: orders_count is count()
}
